{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 8,14,20 * * *"
    }
  ],
  "functions": {
    "api/cron.js": {
      "runtime": "edge"
    }
  }
}